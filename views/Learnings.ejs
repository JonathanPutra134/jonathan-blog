<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <section class="hero-card">
        <%- include("components/navbar", { active: typeof active !== "undefined" ? active : "learnings" }) %>

        <div class="hero-content">
          <div class="hero-copy">
            <h2>PROJECTS </h2>
            <p>
              A showcase and description related to jonathan past projects

            </p>
            <div class="tech-stack" aria-label="Featured tech stack">
              <span class="stack-label">Tech stack covered</span>
              <div class="stack-icons">
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/go/go-original.svg"
                    alt="Golang"
                  />
                  <span>Golang</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg"
                    alt="PostgreSQL"
                  />
                  <span>PostgreSQL</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/redis/redis-original.svg"
                    alt="Redis"
                  />
                  <span>Redis</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg"
                    alt="TypeScript"
                  />
                  <span>TypeScript</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg"
                    alt="Docker"
                  />
                  <span>Docker</span>
                </span>
                <span class="stack-chip">
                  <img
                    class="icon-invert"
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/flask/flask-original.svg"
                    alt="Flask"
                  />
                  <span>Flask</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/laravel/laravel-original.svg"
                    alt="Laravel"
                  />
                  <span>Laravel</span>
                </span>
                <span class="stack-chip">
                  <img
                    src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg"
                    alt="Python"
                  />
                  <span>Python</span>
                </span>
              </div>
            </div>
            <div class="hero-actions">
              <a class="hero-cta" href="#">Discover more</a>
            </div>
          </div>

          <div class="hero-visual">
            <img
              class="hero-model"
              src="/images/jumbotron-learning.png"
              alt="Futuristic hero model"
            />
       
             <div class="hero-title-backdrop" aria-hidden="true">Jonathan Putra</div>
<div class="hero-identity">
  <div class="hero-title-backdrop hero-title-backdrop-home">
    Jonathan Putra
  </div>
  <p class="hero-role">Backend Developer at Kompas Gramedia</p>
  <p class="hero-degree">Bachelor Degree in Computer Science at Multimedia Nusantara University</p>
</div>

          </div>
        </div>

     
      </section>

      <main class="content">
        <section class="section-heading">
          <h2>PROJECTS</h2>
          <p>
            Projects showcase
          </p>
        </section>

        <section class="filters">
          <div class="filter-tabs">
            <button class="tab is-active">All</button>
            <button class="tab">Projects</button>
            <button class="tab">Learnings</button>
            <button class="tab">Careers</button>
          </div>

    
        </section>

        <section class="post-grid">
          <article class="post-card ">
            <div class="post-image image-1">
              <span class="pill">Destination</span>
            </div>
            <div class="project-stack" aria-label="Project tech stack">
              <span>
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/go/go-original.svg" alt="Go" />

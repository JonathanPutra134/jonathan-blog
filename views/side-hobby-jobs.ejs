<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <section class="hero-card">
        <%- include("components/navbar", { active: typeof active !== "undefined" ? active : "side-hobby-jobs" }) %>

        <div class="hero-content">
          <div class="hero-copy">
            <span class="pill">Side Track</span>
            <h2>SIDE HOBBY</h2>
            <h2>&amp; JOBS</h2>
            <p>
              A collection of side activities, hobbies, freelance work, and
              experiments outside the main career and learning path.
            </p>
            <div class="hero-actions">
              <a class="hero-cta" href="#">Explore more</a>
            </div>
          </div>

          <div class="hero-visual">
            <img
              class="hero-model"
              src="/images/jumbotron.png"
              alt="Side hobby and jobs hero"
            />
            <div class="hero-title-backdrop" aria-hidden="true">Side Quest</div>
          </div>
        </div>
      </section>

      <main class="content">
        <section class="section-heading">
          <h2>SIDE HOBBY &amp; JOBS</h2>
          <p>Stories and activities outside the main project timeline.</p>
        </section>

        <section class="post-grid">
          <article class="post-card">
            <div class="post-image image-1">
              <span class="pill">Hobby</span>
            </div>
            <div class="post-meta">Coming soon</div>
            <h3>Side Hobby Notes</h3>
            <p>
              This section is ready for future hobby, freelance, and side-job
              posts.
            </p>
            <a class="read-more" href="#">Read more</a>
          </article>
        </section>
      </main>
    </div>
  </body>
</html>

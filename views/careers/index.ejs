<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="page-shell">
      <section class="hero-card hero-card-home hero-card-projects">
        <%- include("../components/navbar", { active: typeof active !== "undefined" ? active : "careers" }) %>
        <%- include("jumbotron") %>
      </section>

      <main class="content">
        <section class="section-heading">
          <h2>RECENT BLOGS</h2>
          <p>
            Here, we share the most recent blogs and the pinned one
          </p>
        </section>

        <section class="filters">
          <div class="filter-tabs">
            <button class="tab is-active">All</button>
            <button class="tab">Projects</button>
            <button class="tab">Learnings</button>
            <button class="tab">Careers</button>
          </div>
        </section>

        <section class="post-grid">
          <% blogsCareers.forEach((blog) => { %>
            <%- include("../components/post-card", { blog }) %>
          <% }) %>
        </section>
      </main>
    </div>
  </body>
</html>
